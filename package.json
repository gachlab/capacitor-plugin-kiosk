{
  "name": "@gachlab/capacitor-kiosk",
  "version": "2.0.0",
  "description": "Capacitor plugin for Android kiosk mode (Lock Task). Pin your app to the screen and prevent users from leaving.",
  "type": "module",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/"
  ],
  "author": "Guillermo Carrillo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gachlab/capacitor-plugin-kiosk.git"
  },
  "bugs": {
    "url": "https://github.com/gachlab/capacitor-plugin-kiosk/issues"
  },
  "keywords": [
    "capacitor",
    "plugin",
    "native",
    "kiosk",
    "lock-task",
    "screen-pinning",
    "android"
  ],
  "scripts": {
    "verify": "npm run verify:android && npm run verify:web",
    "verify:android": "cd android && ./gradlew clean build test && cd ..",
    "verify:web": "npm run build",
    "lint": "eslint . && npm run prettier -- --check",
    "fmt": "eslint . --fix && npm run prettier -- --write",
    "prettier": "prettier \"**/*.{css,html,ts,js,java}\" --plugin=prettier-plugin-java",
    "build": "npm run clean && vite build",
    "clean": "rimraf ./dist",
    "watch": "vite build --watch",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.1",
    "@capacitor/core": "^8.0.1",
    "@ionic/prettier-config": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^9.39.2",
    "prettier": "^3.8.0",
    "prettier-plugin-java": "^2.8.1",
    "rimraf": "^6.1.2",
    "typescript": "^6.0.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^3.2.1"
  },
  "peerDependencies": {
    "@capacitor/core": "^8.0.1"
  },
  "prettier": "@ionic/prettier-config",
  "capacitor": {
    "android": {
      "src": "android"
    }
  }
}
